# Rust language configuration for rustvim
{ pkgs }:

{
  # LSP server and runtime dependencies
  lspsAndRuntimeDeps = with pkgs; [
    rust-analyzer
    cargo
    clippy
    rustfmt
  ];

  # Debug adapter
  debug = with pkgs; [
    vscode-extensions.vadimcn.vscode-lldb
  ];

  # Code formatter
  formatter = with pkgs; [
    rustfmt
  ];

  # Linter
  linter = "clippy";

  # Package naming
  packageName = "rustvim";
  appName = "rustvim";

